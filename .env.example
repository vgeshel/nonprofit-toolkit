# Donations ETL Configuration
# Copy to .env and fill in values. DO NOT commit .env

# === Core GCP Settings ===
PROJECT_ID=your-gcp-project-id
REGION=us-central1
LOCATION=US

# === Resource Naming ===
BUCKET=${PROJECT_ID}-donations-etl
AR_REPO=donations
IMAGE_NAME=etl
JOB_NAME=donations-etl

# === BigQuery ===
DATASET_RAW=donations_raw
DATASET_CANON=donations

# === ETL Runtime Settings (for local execution with `bun etl:run`) ===
LOOKBACK_HOURS=48
LOG_LEVEL=info

# === Service Accounts ===
RUNTIME_SA=donations-etl-sa
SCHEDULER_SA=donations-etl-scheduler-sa

# === Cloud Scheduler ===
SCHEDULER_JOB_NAME=donations-etl-daily
SCHEDULE="0 9 * * *"
TIME_ZONE=America/Los_Angeles

# === Provision Flags (set to 1 to skip) ===
SKIP_BUILD=0
SKIP_SCHEMA=0
SKIP_SECRETS=0
SKIP_SCHEDULER=0

# === Organization Identity (for letter templates) ===
ORG_NAME=Your Organization
ORG_ADDRESS=
ORG_MISSION=Our organization is dedicated to making a positive impact through charitable giving.
ORG_TAX_STATUS=This organization is a tax-exempt organization under Section 501(c)(3) of the Internal Revenue Code. Our EIN is available upon request.
DEFAULT_SIGNER_NAME=Organization Leader
DEFAULT_SIGNER_TITLE=Director

# === API Secrets ===
# Used by both provisioning (creates Secret Manager secrets) and local execution.
SECRET_MERCURY_API_KEY=
SECRET_PAYPAL_CLIENT_ID=
SECRET_PAYPAL_SECRET=
SECRET_GIVEBUTTER_API_KEY=
SECRET_WISE_TOKEN=
# Patreon Creator's Access Token (OAuth 2.0). Generate at:
# https://www.patreon.com/portal/registration/register-clients
SECRET_PATREON_ACCESS_TOKEN=

# === Wise API Settings ===
# Profile ID from Wise dashboard or API (connector auto-discovers all balances)
WISE_PROFILE_ID=

# === Patreon API Settings ===
# Campaign ID to fetch members/pledges from. Find via the Patreon API
# `/api/oauth2/v2/identity?include=memberships.campaign` or your campaign URL.
PATREON_CAMPAIGN_ID=

# === Google Sheets - Check Deposits ===
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
CHECK_DEPOSITS_SPREADSHEET_ID=
CHECK_DEPOSITS_SHEET_NAME=checks

# === AI Agent ===
# Google Generative AI API key (from https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# Model for donation query agent (default: gemini-3.1-flash-lite-preview)
AGENT_MODEL=

# === Slack Service ===
# API key for authenticating REST API calls
SERVICE_API_KEY=
# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=
# Slack Signing Secret for verifying Slack requests
SLACK_SIGNING_SECRET=
# Port for the service (default: 8080)
PORT=8080

# === Reports ===
# Slack channel ID for posting donation reports (e.g., C0123456789)
REPORT_SLACK_CHANNEL=
# Cloud Scheduler cron expressions for report jobs
REPORT_WEEKLY_SCHEDULE=0 8 * * 1
REPORT_MONTHLY_SCHEDULE=0 8 1 * *
